// Restaurant owner menu: categories per user (create first, then assign to items)
model MenuCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String   // e.g. "Main Course", "Breads"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MenuItem[]

  @@index([userId])
}

// Restaurant owner menu: structured items (itemName, price, image) per user
model MenuItem {
  id         String   @id @default(uuid())
  userId     String   // Owner (restaurant) this menu belongs to
  categoryId String?  // Optional: link to owner's menu category
  itemName   String
  description String?  // Optional description for customers
  price      Float    // e.g. 12.00
  imageUrl   String?  // Optional image URL (uploaded to R2 or URL)
  sortOrder  Int      @default(0)
  /// veg | egg | non_veg — for customer filters (optional)
  dietaryType String?
  allergens  String[] @default([]) // e.g. ["gluten","nuts","milk"]
  allergenIconUrls String[] @default([]) // custom uploaded allergen icons
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems RestaurantOrderItem[]

  @@index([userId])
  @@index([categoryId])
}

// Optional: owner uploads menu as PDF or image (for admin reference / display)
model MenuFile {
  id       String   @id @default(uuid())
  userId   String
  fileUrl  String
  fileType String   // pdf | image
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Restaurant order: placed by a user (customer) with a restaurant (owner)
model RestaurantOrder {
  id              String      @id @default(uuid())
  userId          String      // Customer who placed the order
  ownerId         String      // Restaurant owner
  status          RestaurantOrderStatus @default(pending)
  totalAmount     Float       @default(0)
  taxCharge       Float       @default(0) // Distance-based delivery tax/charge at order time
  deliveryDistanceKm Float?   // Customer distance from restaurant when order placed (km)
  currency        String      @default("BDT")
  deliveryAddress String?     // Optional delivery/notes
  customerPhone   String?     // Contact phone at time of order
  fulfillmentType String      @default("delivery") // collection | delivery
  promotionId     String?
  promoCode       String?
  discountAmount  Float       @default(0)
  riderId         String?     // Assigned delivery rider (owner's rider account)
  assignedAt      DateTime?   // When owner assigned the rider
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user   User       @relation("RestaurantOrderCustomer", fields: [userId], references: [id], onDelete: Cascade)
  owner  User       @relation("RestaurantOrderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  rider  User?      @relation("RestaurantOrderRider", fields: [riderId], references: [id], onDelete: SetNull)
  items  RestaurantOrderItem[]
  review RestaurantOrderReview?

  @@index([userId])
  @@index([ownerId])
  @@index([riderId])
  @@index([status])
  @@index([createdAt])
}

// Customer review for a restaurant order (one per order)
model RestaurantOrderReview {
  id        String   @id @default(uuid())
  orderId   String   @unique
  userId    String   // Customer who reviews
  ownerId   String   // Restaurant owner (denormalized for admin filtering)
  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User           @relation("RestaurantOrderReviewUser", fields: [userId], references: [id], onDelete: Cascade)
  owner User           @relation("RestaurantOrderReviewOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ownerId])
  @@index([rating])
  @@index([createdAt])
}

enum RestaurantOrderStatus {
  pending
  confirmed
  preparing
  ready
  rider_assigned
  rider_accepted
  out_for_delivery
  delivery_complete
  completed
  cancelled
}

model RestaurantOrderItem {
  id          String   @id @default(uuid())
  orderId     String
  menuItemId  String
  itemName    String   // Snapshot at order time
  unitPrice   Float    // Snapshot at order time
  quantity    Int      @default(1)

  order    RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
}

model RestaurantBooking {
  id              String   @id @default(uuid())
  userId          String
  ownerId         String
  status          RestaurantBookingStatus @default(pending)
  customerName    String
  customerAddress String
  customerPhone   String
  persons         Int
  bookingDate     DateTime
  promotionId     String?
  discountPercent Float?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User @relation("RestaurantBookingCustomer", fields: [userId], references: [id], onDelete: Cascade)
  owner User @relation("RestaurantBookingOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ownerId])
  @@index([status])
  @@index([bookingDate])
  @@index([createdAt])
}

enum RestaurantBookingStatus {
  pending
  confirmed
  completed
  cancelled
}

// ============================================
// PROMOTION - Owner-only; like post (thumbnail/video) + promoAmount, promoCode, start/expire, menu items
// ============================================
model Promotion {
  id            String    @id @default(uuid())
  userId        String    // Owner who created (role must be owner)
  title         String
  description   String?
  thumbnailUrl  String?   // R2 URL
  videoUrl      String?   // R2 URL (optional)
  mediaType     String    @default("image") // image | video
  duration      Int?      // Seconds when video
  promoAmount   Float     @default(0) // Discount % for order promos (e.g. 10 = 10%)
  promoCode     String    @default("") // Code user enters (e.g. EATIX20)
  offerType     String    @default("order") // order | amount_discount | booking_discount
  fulfillmentScopes String[] @default([]) // collection | delivery | both
  discountTiers Json?     // [{ minValue, maxValue?, percent, metricType?: amount|people }]
  tierMetricType String?  // people | amount — default metric for booking_discount tiers
  startDate     DateTime  // When promotion becomes active
  expireDate    DateTime  // When promotion ends
  menuItemIds   String[]  @default([]) // IDs of menu items included in this offer
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
  @@index([expireDate])
}
