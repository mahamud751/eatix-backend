  caption           String?
  content           String?
  scheduledAt       DateTime?
  publishedAt       DateTime?
  
  // Media
  mediaUrls         Json[]   @default([])
  
  // Engagement Metrics
  likes             Int      @default(0)
  comments          Int      @default(0)
