// ============================================
// SPONSORED VIDEO - Location-based paid promotion
// Owner/Admin creates sponsored for an area; when user selects "Use my location", sponsored for that area is shown
// ============================================
model SponsoredVideo {
  id          String   @id @default(uuid())
  videoId     String   // Video to promote
  userId      String   // Owner this sponsored is for (home shows this user's details)
  areaName    String   // e.g. "Mirpur 10", "Dhanmondi"
  latitude    Float    // Center of sponsored area
  longitude   Float
  radiusKm    Float    @default(2) // Radius in km - user within this distance sees this sponsored
  startDate   DateTime // Campaign start
  endDate     DateTime // Campaign end - after this, no longer shown
  amountPaid  Float    // How much was paid for this sponsorship
  currency    String   @default("BDT")
  status      SponsoredStatus @default(active) // active | expired | cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
  @@index([latitude])
  @@index([longitude])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
}

enum SponsoredStatus {
  active
  expired
  cancelled
}

// ============================================
// FEATURED VIDEO - Location-based featured (same logic as sponsored, separate)
// ============================================
model FeaturedVideo {
  id          String   @id @default(uuid())
  videoId     String
  userId      String   // Owner this featured is for (home shows this user's details)
  areaName    String
  latitude    Float
  longitude   Float
  radiusKm    Float    @default(2)
  startDate   DateTime
  endDate     DateTime
  amountPaid  Float    // Optional cost tracking
  currency    String   @default("BDT")
  status      FeaturedStatus @default(active)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
  @@index([latitude])
  @@index([longitude])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
}

enum FeaturedStatus {
  active
  expired
  cancelled
}

