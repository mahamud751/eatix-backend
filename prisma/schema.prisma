// Video Upload System Models
model Video {
  id              String         @id @default(uuid())
  userId          String         // User who uploaded the video
  title           String
  description     String?
  videoUrl        String         // R2 video URL
  thumbnailUrl    String         // R2 thumbnail URL
  duration        Int?           // Video duration in seconds
  fileSize        Int?           // File size in bytes
  mimeType        String?        // video/mp4, etc.
  width           Int?           // Video width
  height          Int?           // Video height
  status          VideoStatus    @default(processing)
  visibility      VideoVisibility @default(public)
  viewCount       Int            @default(0)
  likeCount       Int            @default(0)
  dislikeCount    Int            @default(0)
  commentCount    Int            @default(0)
  shareCount      Int            @default(0)
  category        String?        // Video category
  tags            String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?      // When video was published
  scheduledPublishAt DateTime?   // If set, video appears in public feeds only when now >= this (local midnight of chosen day as UTC stored from client)

  // Relations
  user            User           @relation("UserVideos", fields: [userId], references: [id], onDelete: Cascade)
  likes           VideoLike[]    @relation("VideoLikes")
  dislikes        VideoDislike[] @relation("VideoDislikes")
  comments        VideoComment[] @relation("VideoComments")
views           VideoView[]    @relation("VideoViews")
  watchLater      VideoWatchLater[] @relation("VideoWatchLater")
  favorites       VideoFavorite[]   @relation("VideoFavorites")
  sponsored       SponsoredVideo[]
  featured        FeaturedVideo[]
  vendorFeatured  VendorFeaturedVideo[]
  vendorSponsored VendorSponsoredVideo[]

  @@index([userId])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
  @@index([viewCount])
  @@index([scheduledPublishAt])
}

