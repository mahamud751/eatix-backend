  filterId        String?        // Applied filter
  filterName      String?
  soundId         String?        // Linked sound/audio
  soundTitle      String?
  soundArtist     String?
  soundUrl        String?
  beautyLevel     Int?           @default(0) // 0-100
  timerSeconds    Int?           // Countdown timer (3, 5, 10)
  speedFactor     Float?         @default(1) // 0.5x, 1x, 2x, 3x - like YouTube Shorts
  cameraFacing    String?        // front | back - for flip

  // Comments & visibility
  commentSetting  String         @default("allow") // allow, hold, disable
  visibility      ShortVisibility @default(public)
  isLive          Boolean        @default(false) // Live stream flag
  liveChannelId   String?        // Agora channel when live

  status          ShortStatus    @default(processing)
  viewCount       Int            @default(0)
  likeCount       Int            @default(0)
  dislikeCount    Int            @default(0)
  commentCount    Int            @default(0)
  shareCount      Int            @default(0)
  category        String?
  tags            String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?

  user            User           @relation("UserShorts", fields: [userId], references: [id], onDelete: Cascade)
  likes           ShortLike[]    @relation("ShortLikes")
  dislikes        ShortDislike[] @relation("ShortDislikes")
  comments        ShortComment[] @relation("ShortComments")
  views           ShortView[]    @relation("ShortViews")
  watchLater      ShortWatchLater[] @relation("ShortWatchLater")
  favorites       ShortFavorite[]   @relation("ShortFavorites")

  @@index([userId])
  @@index([status])
  @@index([visibility])
  @@index([createdAt])
  @@index([viewCount])
  @@index([isLive])
}

